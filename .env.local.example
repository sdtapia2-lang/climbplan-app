# Copia este archivo a .env.local y completa con los datos de tu proyecto Supabase
# (Project Settings > API en el dashboard de supabase.com)
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key

# Service role key (Project Settings > API > service_role). NUNCA le pongas el
# prefijo NEXT_PUBLIC_ -- si lo hicieras quedaria expuesta en el navegador.
# Solo la usan los Route Handlers server-side (ej: /api/create-athlete) para
# crear cuentas de escaladores en nombre de un entrenador/admin.
# En Vercel: agregala como variable de entorno del proyecto, no la subas a git.
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key
